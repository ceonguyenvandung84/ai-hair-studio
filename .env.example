# Google Cloud Service Account (JSON string)
# Lấy từ GCP IAM -> Service Accounts -> Create Key -> JSON
# Set trên Cloudflare Dashboard dạng secret
GOOGLE_SA_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"...","private_key_id":"..."}

# JWT Secret cho auth (tự tạo random string)
JWT_SECRET=your-random-jwt-secret-at-least-32-chars

# Cloudflare D1 Database ID
DATABASE_ID=xxxxx
